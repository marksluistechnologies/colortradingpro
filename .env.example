# Telegram Bot Token - @BotFather se lo
BOT_TOKEN=7112345678:AAGxYz1234567890AbCdEfGhIjKlMnOpQrStU

# Google Sheet ID - Sheet URL se copy karo
# Example: https://docs.google.com/spreadsheets/d/1AbC123.../edit
GOOGLE_SHEET_ID=1AbC1234567890XyZ

# Google Service Account ka JSON (saara content ek line mein)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Vercel Webhook URL - Deploy ke baad milega
WEBHOOK_URL=https://your-app-name.vercel.app/api/bot

# Optional: Sirf specific Telegram IDs ko allow karo (comma-separated)
ALLOWED_USER_IDS=123456789,987654321